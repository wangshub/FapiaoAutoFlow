# 复制为 .env 并填入真实值。.env 不会被提交(见 .gitignore)。

# ===== 邮箱 IMAP(QQ / 163)=====
# QQ:  imap.qq.com   163: imap.163.com
IMAP_HOST=imap.163.com
IMAP_PORT=993
IMAP_USER=your_email@163.com
# 注意:这里填「授权码 / 应用密码」,不是邮箱登录密码。
# 163: 设置 -> POP3/SMTP/IMAP -> 开启 IMAP -> 应用密码
# QQ:  设置 -> 账户 -> 开启 IMAP/SMTP -> 生成授权码
IMAP_PASSWORD=your_app_password

# ===== AI 识别:OpenAI 兼容接口 =====
LLM_API_KEY=sk-xxxxxxxx
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_MODEL=glm-5
# 视觉模型(识别图片/扫描件发票)。留空则复用 LLM_MODEL;
# 若 LLM_MODEL 不支持图片,需在此填一个多模态模型(如 qwen-vl-max)。
LLM_VISION_MODEL=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
